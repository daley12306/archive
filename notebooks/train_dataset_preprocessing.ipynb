    "def extract_qualification(text):\n",
    "    start_keywords = ['YÊU CẦU ỨNG VIÊN', 'Yêu cầu ứng viên', 'Yêu cầu công việc', 'Yêu Cầu Công Việc']\n",
    "    end_keywords = ['Thu nhập', 'Quyền lợi', 'Phúc lợi', 'Địa điểm làm việc', 'Thông tin khác', 'Các phúc lợi dành cho bạn']\n",
    "\n",
    "    start_pos = -1\n",
    "    for kw in start_keywords:\n",
    "        match = re.search(kw, text, re.IGNORECASE)\n",
    "        if match:\n",
    "            start_pos = match.end()\n",
    "            break\n",
    "\n",
    "    if start_pos == -1:\n",
    "        return \"\"\n",
    "    \n",
    "    all_end_pos = []\n",
    "    for kw in end_keywords:\n",
    "        match = re.search(kw, text[start_pos:], re.IGNORECASE)\n",
    "        if match:\n",
    "            all_end_pos.append(start_pos + match.start())\n",
    "\n",
    "    end_pos = min(all_end_pos) if all_end_pos else len(text)\n",
    "    print(end_pos)\n",
    "\n",
    "    return text[start_pos:end_pos].strip()"
   ]
  },
