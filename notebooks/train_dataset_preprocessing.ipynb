    "import numpy as np\n",
    "\n",
    "def balanced_sample_filled(df_pandas, cat_col=\"category\", n_total=2000, random_state=42):\n",
    "    rng = np.random.RandomState(random_state)\n",
    "    cats = df_pandas[cat_col].unique()\n",
    "    k = len(cats)\n",
    "    if len(df_pandas) <= n_total:\n",
    "        return df_pandas.sample(frac=1, random_state=random_state).reset_index(drop=True)\n",
    "\n",
    "    n_each = n_total // k\n",
    "\n",
    "    # 1) lấy cân bằng cơ bản\n",
    "    base = (\n",
    "        df_pandas.groupby(cat_col, group_keys=False)\n",
    "          .apply(lambda x: x.sample(n=min(len(x), n_each), random_state=random_state))\n",
    "    )\n",
    "\n",
    "    # 2) pool còn lại sau khi đã lấy base\n",
    "    remaining_pool = df_pandas.drop(base.index)\n",
    "\n",
    "    # 3) phân bổ phần thiếu theo vòng tròn\n",
    "    need = n_total - len(base)\n",
    "    extra_parts = []\n",
    "\n",
    "    # map: cat -> các dòng còn lại của cat\n",
    "    pool_by_cat = {c: remaining_pool[remaining_pool[cat_col] == c] for c in cats}\n",
    "\n",
    "    # vòng tròn: mỗi lượt cố gắng lấy 1 dòng/cat nếu còn\n",
    "    while need > 0:\n",
    "        progressed = False\n",
    "        for c in cats:\n",
    "            if need <= 0:\n",
    "                break\n",
    "            pool_c = pool_by_cat[c]\n",
    "            if len(pool_c) > 0:\n",
    "                take = pool_c.sample(n=1, random_state=rng.randint(0, 10**9))\n",
    "                extra_parts.append(take)\n",
    "                # cập nhật pool\n",
    "                pool_by_cat[c] = pool_c.drop(take.index)\n",
    "                need -= 1\n",
    "                progressed = True\n",
    "        if not progressed:\n",
    "            # không còn gì để lấy\n",
    "            break\n",
    "\n",
    "    extra = pd.concat(extra_parts) if extra_parts else pd.DataFrame(columns=df.columns)\n",
    "    out = pd.concat([base, extra]).sample(frac=1, random_state=random_state).reset_index(drop=True)\n",
    "    return out\n",
    "\n",
    "# dùng:\n",
    "df_sample = balanced_sample_filled(df_pandas, cat_col=\"category\", n_total=200, random_state=42)\n",
    "print(len(df_sample))\n",
    "print(df_sample[\"category\"].value_counts())"
