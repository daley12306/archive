   "source": [
    "def preprocess_requirement(text: str):\n",
    "    if not isinstance(text, str):\n",
    "        return \"\"\n",
    "    text = re.sub(r\"</?p>|</?strong>|</?em>|<br />|<br>|<br..\", \" \", text, flags=re.IGNORECASE)\n",
    "    text = re.sub(r'^[\\-\\–]\\s*', '', text, flags=re.MULTILINE)\n",
    "    text = re.sub(r\"[➢▸ü·\\r\\t•●▪◦\\*\\+\\:\\n]+\", \" \", text)\n",
    "    text = re.sub(r\"\\b([A-Za-z]|[IVXLCM]+|\\d+)\\.\", \" \", text)\n",
    "    text = re.sub(r\"\\n{2,}\", \" \", text)  \n",
    "    text = re.sub(r\"\\s{2,}\", \" \", text)\n",
    "    # Tách các từ dính liền nhau\n",
    "    text = regex.sub(r'(?<!\\s)(?=\\p{Lu}\\p{Ll})', ' ', text)\n",
    "    text = regex.sub(r'(?<=\\p{Ll})(?=\\p{Lu}\\p{Ll})', ' ', text)\n",
    "    return text.strip()"
   ]
  },
